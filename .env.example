# ═══════════════════════════════════════════════════════
#  Vita IA — Variables de Entorno para Producción
# ═══════════════════════════════════════════════════════
# Copiar a .env y configurar antes de desplegar
# ═══════════════════════════════════════════════════════

# ─── Servidor ─────────────────────────────────────────

# URL pública de la aplicación (para OAuth, Stripe redirects)
APP_URL="https://tu-dominio.com"

# Puerto del servidor (default: 3000)
PORT=3000

# Entorno: development | production
NODE_ENV=production

# ─── AI Multi-Proveedor ─────────────────────────────

# Gemini API Key (Google AI Studio) — REQUERIDO para análisis de imágenes
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# OpenRouter API Key — REQUERIDO para chat, recetas, rutinas (DeepSeek)
# https://openrouter.ai/keys
# Modelos gratuitos usados: deepseek/deepseek-chat-v3-0324:free
OPENROUTER_API_KEY=""

# ─── Firebase ────────────────────────────────────────

# Project ID de Firebase (default del proyecto)
FIREBASE_PROJECT_ID="vitaia-ea02e"

# Para Firebase Admin SDK en el servidor (service account JSON)
# Opción A: Variable de entorno en GCP Cloud Run (Application Default Credentials)
# Opción B: Archivo JSON de cuenta de servicio
# GOOGLE_APPLICATION_CREDENTIALS="/ruta/a/service-account-key.json"

# ─── Stripe (Pagos) ──────────────────────────────────

# Secret key de Stripe (sk_live_... o sk_test_... para pruebas)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""

# Webhook signing secret (whsec_...)
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=""

# Price IDs de los productos en Stripe
# Crear en Stripe Dashboard > Productos:
#   - Vita IA Plus: $7.99/mes (suscripción recurrente)
#   - Vita IA Max:  $15.00/mes (suscripción recurrente)
STRIPE_PRICE_PREMIUM=""
STRIPE_PRICE_MAX=""

# ─── GROQ (Legacy — opcional) ────────────────────────

GROQ_API_KEY=""
